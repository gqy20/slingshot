[gd_resource type="Theme" load_steps=5 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/NotoSansSC-VF.otf" id="1_font"]

[sub_resource type="FontVariation" id="FontVariation_regular"]
base_font = ExtResource("1_font")
variation_opentype = {
"wght": 400.0
}

[sub_resource type="FontVariation" id="FontVariation_medium"]
base_font = ExtResource("1_font")
variation_opentype = {
"wght": 600.0
}

[sub_resource type="FontVariation" id="FontVariation_bold"]
base_font = ExtResource("1_font")
variation_opentype = {
"wght": 700.0
}

[resource]
default_font = SubResource("FontVariation_regular")
default_font_size = 27
VideoRegular/base_type = &"Label"
VideoRegular/fonts/font = SubResource("FontVariation_regular")
VideoMedium/base_type = &"Label"
VideoMedium/fonts/font = SubResource("FontVariation_medium")
VideoBold/base_type = &"Label"
VideoBold/fonts/font = SubResource("FontVariation_bold")
