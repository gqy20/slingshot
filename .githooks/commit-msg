#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file is required}"
subject="$(head -n 1 "$message_file")"

if [[ "$subject" =~ ^(Merge|Revert)[[:space:]] ]] \
  || [[ "$subject" =~ ^(fixup|squash)! ]]; then
  exit 0
fi

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore)(\([a-z0-9][a-z0-9._/-]*\))?!?: .{3,72}$'
if [[ ! "$subject" =~ $pattern ]]; then
  cat >&2 <<'EOF'
commit-msg: use Conventional Commits:
  feat(scope): concise description
  fix(scope): concise description
  docs: concise description

Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore.
The subject after ": " must contain 3-72 characters.
EOF
  exit 1
fi
